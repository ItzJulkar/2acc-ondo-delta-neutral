# ============================================================
# Ondo Perps — Dual Account API Keys
# Copy this file to .env and fill in your real values.
# NEVER commit .env or share secrets on GitHub / chat.
# ============================================================
# Generate keys: app.ondoperps.xyz → API Keys
# Recommended: Trade permission ONLY, Withdrawal OFF, IP whitelist ON
# Docs: https://docs.ondoperps.xyz/api-reference/api_key_authentication

# --- Account 1 (places A = long entry, B = close sell) ---
ONDO_KEY_ID_1=ondoKeyId_REPLACE_ME
ONDO_API_SECRET_1=ondoApiSecret_REPLACE_ME

# --- Account 2 (places C = short entry, D = close buy) ---
ONDO_KEY_ID_2=ondoKeyId_REPLACE_ME
ONDO_API_SECRET_2=ondoApiSecret_REPLACE_ME

# Optional overrides (defaults match config.yaml)
# ONDO_BASE_URL=https://api.ondoperps.xyz
# DRY_RUN=false
